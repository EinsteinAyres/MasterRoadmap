		{"id":"53b3345ea8c9893a","type":"text","text":"Fase 1\nFundamentos\n(SQL, Python, Docker)","x":16730,"y":-1118,"width":260,"height":120},
		{"id":"1e459429ccbc0631","type":"text","text":"Fase 2\nPipelines\n(ETL, Airflow, dbt)","x":16730,"y":-918,"width":260,"height":120},
		{"id":"18d6b9b98044abb1","type":"text","text":"Fase 3\nData Warehouse\n(Modelagem, Governança)","x":16730,"y":-738,"width":260,"height":120},
